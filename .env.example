# ============================================================
# CREDENCIAIS — copie para .env e preencha. NUNCA commite .env.
# ============================================================

# LLM Provider — use Groq (gratuito) ou Gemini. A chave presente define o provider.
# Groq (recomendado, gratuito): https://console.groq.com
GROQ_API_KEY=SUA_GROQ_API_KEY_AQUI
# Gemini (alternativo): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Modelo (opcional — usa padrão do provider se vazio)
# Groq: llama-3.3-70b-versatile | Gemini: gemini-2.0-flash
LLM_MODEL=

# Telegram Bot (rotacione via @BotFather → /revoke)
TELEGRAM_BOT_TOKEN=SEU_BOT_TOKEN_AQUI
# Chat ID do admin (recebe notificações de execução do cron). Não é o usuário do bot.
TELEGRAM_CHAT_ID=SEU_CHAT_ID_AQUI

# URL base pública onde os HTMLs ficam hospedados (GitHub Pages, Vercel, custom).
# Usada para gerar link compartilhável nas respostas do bot e na tag canonical.
# Exemplo: https://SEU_USUARIO.github.io/analise-tecnica-genial
PUBLIC_BASE_URL=

# WordPress REST API (opcional — deixe em branco para pular publicação)
# Gere um Application Password em: WP Admin → Usuários → Perfil → Senhas de aplicativo
WORDPRESS_URL=
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=
# IDs das páginas no WordPress (uma para cada ativo)
WORDPRESS_PAGE_ID_IBOV=
WORDPRESS_PAGE_ID_WIN=
WORDPRESS_PAGE_ID_WDO=

# Quais ativos publicar nesta execução (lista separada por vírgula)
# Valores válidos: IBOV, WIN, WDO  -- ou ALL
PUBLISH_ASSETS=ALL

# Diretório de saída dos HTMLs estáticos
OUTPUT_DIR=public
